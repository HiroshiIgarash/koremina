# E2Eテスト用環境変数テンプレート
# このファイルをコピーして .env.test を作成し、実際の値を設定してください
# .env.test は .gitignore に追加されています

DATABASE_URL="postgresql://admin:password@localhost:5432/koremina_test"
DATABASE_URL_UNPOOLED="postgresql://admin:password@localhost:5432/koremina_test"

# E2Eテスト専用のAUTH_SECRETを発行してください（本番環境と共有しないこと）
# 生成方法: openssl rand -base64 32
AUTH_SECRET="test-secret-for-e2e-at-least-32-characters-long-xxx"

# テスト用ダミー値 (実際のOAuthは使用しない)
AUTH_GOOGLE_ID="test-google-id"
AUTH_GOOGLE_SECRET="test-google-secret"
AUTH_TWITTER_ID="test-twitter-id"
AUTH_TWITTER_SECRET="test-twitter-secret"
YT_API_KEY="test-youtube-api-key"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_test_dummy"
MAILER_USER="test@example.com"
MAILER_PASS="test-password"
EMAIL_TOKEN_HMAC_SECRET="test-hmac-secret-at-least-32-characters-xxxx"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
