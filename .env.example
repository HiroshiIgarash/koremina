# =============================================================================
# koremina 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、各値を設定してください。
# cp .env.example .env.local
# =============================================================================

# --- データベース (Neon PostgreSQL) ---
# 開発: ローカルの PostgreSQL 接続文字列
# 本番: Neon の接続プール URL
DATABASE_URL="postgresql://admin:password@localhost:5432/postgres"

# 直接接続（マイグレーション用）
DATABASE_URL_UNPOOLED="postgresql://admin:password@localhost:5432/postgres"

# ローカル DB URL (prisma:studio:dev で使用)
POSTGRES_LOCAL_URL="postgresql://admin:password@localhost:5432/postgres"

# --- NextAuth.js ---
# 生成方法: openssl rand -base64 32
AUTH_SECRET="your-nextauth-secret-here"

# Google OAuth (https://console.cloud.google.com/)
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Twitter/X OAuth (https://developer.twitter.com/)
AUTH_TWITTER_ID="your-twitter-client-id"
AUTH_TWITTER_SECRET="your-twitter-client-secret"

# --- 外部サービス ---
# YouTube Data API v3 (https://console.cloud.google.com/)
YT_API_KEY="your-youtube-api-key"

# Vercel Blob Storage (https://vercel.com/storage/blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# --- メール通知 (Nodemailer + Gmail SMTP) ---
MAILER_USER="your-gmail-address@gmail.com"
# Gmail アプリパスワード (https://myaccount.google.com/apppasswords)
MAILER_PASS="your-gmail-app-password"

# --- メール確認 (ダブルオプトイン) ---
# 256bit 以上のランダムな文字列
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
EMAIL_TOKEN_HMAC_SECRET="your-hmac-secret-here"

# --- アプリケーション ---
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Vercel Preview URL (プレビュー環境のみ)
# VERCEL_PREVIEW_URL="your-project-git-preview-yourname.vercel.app"
